{
  "name": "yuragi",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "build:client": "vite build",
    "check": "bunx tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "ci": "bun run check && bun run build && biome ci .",
    "create-account": "bun run src/create-account.ts",
    "change-password": "bun run src/change-password.ts",
    "delete-account": "bun run src/delete-account.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "vite": "^8.1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@fedify/fedify": "^2.3.1",
    "@fedify/hono": "^2.3.1",
    "@hono/zod-validator": "^0.8.0",
    "antd": "^6.5.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.27",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "zod": "^4.4.3"
  }
}
